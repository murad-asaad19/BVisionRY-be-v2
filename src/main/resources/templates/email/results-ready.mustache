{{>_layout-header}}
<h2 style="margin: 0 0 18px; font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; font-size: 22px; font-weight: 600; letter-spacing: -0.02em; line-height: 1.3; color: #051647;">{{{fields.heading}}}</h2>

<p style="margin: 0 0 16px; font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; font-size: 16px; line-height: 1.6; color: #060021;">{{{fields.greeting}}}</p>

<p style="margin: 0 0 16px; font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; font-size: 16px; line-height: 1.6; color: #060021;">{{{fields.mainMessage}}}</p>

<!-- Results Card (achievement) -->
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin: 24px 0;">
    <tr>
        <td style="background-color: #faf2e2; border: 1px solid #f0e2c4; border-left: 4px solid #d9ad62; border-radius: 10px; padding: 18px 20px;">
            <h3 style="margin: 0; font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; font-size: 15px; font-weight: 600; letter-spacing: -0.01em; color: #051647;">{{{fields.cardHeading}}}</h3>
            <p style="margin: 8px 0 0; font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; font-size: 14px; line-height: 1.5; font-weight: 600; color: #2c7a52;">{{{fields.cardStatusLine}}}</p>
        </td>
    </tr>
</table>

<!-- CTA Button -->
<table role="presentation" cellpadding="0" cellspacing="0" border="0" align="center" style="margin: 28px auto;">
    <tr>
        <td align="center" style="border-radius: 10px; background-color: #051647;">
            <a href="{{resultsUrl}}" style="display: inline-block; padding: 14px 34px; font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; font-size: 16px; font-weight: 600; letter-spacing: -0.01em; color: #ffffff; text-decoration: none; border-radius: 10px;">{{{fields.ctaLabel}}} &#8594;</a>
        </td>
    </tr>
</table>

<p style="margin: 0 0 6px; font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; font-size: 13px; line-height: 1.5; color: #55647d;">If the button above doesn't work, copy and paste this link into your browser:</p>
<p style="margin: 0; word-break: break-all; font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; font-size: 13px; line-height: 1.5;"><a href="{{resultsUrl}}" style="color: #005392; text-decoration: underline;">{{resultsUrl}}</a></p>

{{#showPostCompletion}}
<!-- Post-completion follow-up (survey or external link). -->
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin: 36px 0 8px;">
    <tr><td style="border-top: 1px solid #dce3ee; font-size: 0; line-height: 0;">&nbsp;</td></tr>
</table>
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
    <tr>
        <td align="center" style="padding: 16px 0 8px;">
            <p style="margin: 0 0 6px; font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; font-size: 16px; font-weight: 700; letter-spacing: -0.01em; color: #051647;">{{{fields.postCompletionHeading}}}</p>
            <p style="margin: 0 0 18px; font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; font-size: 14px; line-height: 1.5; color: #55647d;">{{{fields.postCompletionBody}}}</p>
            {{#postCompletionUrl}}
            <table role="presentation" cellpadding="0" cellspacing="0" border="0" align="center" style="margin: 0 auto;">
                <tr>
                    <td align="center" style="border-radius: 10px; background-color: #ffffff; border: 2px solid #051647;">
                        <a href="{{postCompletionUrl}}" style="display: inline-block; padding: 11px 28px; font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; font-size: 14px; font-weight: 600; letter-spacing: -0.01em; color: #051647; text-decoration: none;">{{postCompletionLabel}}</a>
                    </td>
                </tr>
            </table>
            {{/postCompletionUrl}}
        </td>
    </tr>
</table>
{{/showPostCompletion}}
{{>_layout-footer}}
