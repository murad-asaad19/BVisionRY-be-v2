{{>_layout-header}}
<h2 style="margin: 0 0 18px; font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; font-size: 22px; font-weight: 600; letter-spacing: -0.02em; line-height: 1.3; color: #051647;">{{{fields.heading}}}</h2>

<p style="margin: 0 0 16px; font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; font-size: 16px; line-height: 1.6; color: #060021;">{{{fields.greeting}}}</p>

<p style="margin: 0 0 16px; font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; font-size: 16px; line-height: 1.6; color: #060021;">{{{fields.mainMessage}}}</p>

<!-- Assessment Card -->
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin: 24px 0;">
    <tr>
        <td style="background-color: #f8f9fc; border: 1px solid #dce3ee; border-left: 4px solid #051647; border-radius: 10px; padding: 18px 20px;">
            <h3 style="margin: 0; font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; font-size: 15px; font-weight: 600; letter-spacing: -0.01em; color: #051647;">{{{fields.cardHeading}}}</h3>
            <p style="margin: 8px 0 0; font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; font-size: 14px; line-height: 1.5; color: #55647d;">{{{fields.cardSubline}}}</p>
        </td>
    </tr>
</table>

<!-- CTA Button -->
<table role="presentation" cellpadding="0" cellspacing="0" border="0" align="center" style="margin: 28px auto;">
    <tr>
        <td align="center" style="border-radius: 10px; background-color: #051647;">
            <a href="{{assessmentUrl}}" style="display: inline-block; padding: 14px 34px; font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; font-size: 16px; font-weight: 600; letter-spacing: -0.01em; color: #ffffff; text-decoration: none; border-radius: 10px;">{{{fields.ctaLabel}}} &#8594;</a>
        </td>
    </tr>
</table>

<p style="margin: 0 0 6px; font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; font-size: 13px; line-height: 1.5; color: #55647d;">If the button above doesn't work, copy and paste this link into your browser:</p>
<p style="margin: 0; word-break: break-all; font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; font-size: 13px; line-height: 1.5;"><a href="{{assessmentUrl}}" style="color: #005392; text-decoration: underline;">{{assessmentUrl}}</a></p>
{{>_layout-footer}}
