<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <springProfile name="local,default,dev,e2e">
        <include resource="org/springframework/boot/logging/logback/console-appender.xml"/>
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
        <!-- Verbose app logging is a DEV convenience only. It used to live outside
             the profile blocks, so it also applied in prod — leaking internal
             detail and bloating logs on the hot path (F22). Scoped to non-prod. -->
        <logger name="com.bvisionry" level="DEBUG"/>
    </springProfile>

    <springProfile name="prod">
        <appender name="JSON_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="ch.qos.logback.classic.encoder.JsonEncoder"/>
        </appender>
        <root level="INFO">
            <appender-ref ref="JSON_CONSOLE"/>
        </root>
        <logger name="com.bvisionry" level="INFO"/>
    </springProfile>
</configuration>
