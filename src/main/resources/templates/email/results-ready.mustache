<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Results Ready</title>
</head>
<body style="font-family: 'Segoe UI', Arial, sans-serif; max-width: 600px; margin: 0 auto; padding: 0; background-color: #f8f8f8;">
    <!-- Header -->
    <div style="background-color: #0f3460; padding: 24px 32px; text-align: center;">
        <h1 style="color: #ffffff; margin: 0; font-size: 24px;">
            <span style="color: #ffc107;">B</span>VisionRY
        </h1>
    </div>

    <!-- Content -->
    <div style="background-color: #ffffff; padding: 32px;">
        <h2 style="color: #0f3460; margin-top: 0;">{{{fields.heading}}}</h2>

        <p style="color: #212529;">{{{fields.greeting}}}</p>

        <p style="color: #212529;">{{{fields.mainMessage}}}</p>

        <!-- Assessment Card -->
        <div style="background: #f8f8f8; border-left: 4px solid #ffc107; border-radius: 8px; padding: 20px; margin: 24px 0;">
            <h3 style="color: #0f3460; margin: 0;">{{{fields.cardHeading}}}</h3>
            <p style="color: #15803d; margin: 8px 0 0; font-size: 14px; font-weight: 600;">{{{fields.cardStatusLine}}}</p>
        </div>

        <!-- CTA Button -->
        <div style="text-align: center; margin: 32px 0;">
            <a href="{{resultsUrl}}"
               style="display: inline-block; background-color: #0f3460; color: #ffffff; text-decoration: none; padding: 14px 32px; border-radius: 8px; font-size: 16px; font-weight: 600;">
                {{{fields.ctaLabel}}} &#8594;
            </a>
        </div>

        <p style="color: #94a3b8; font-size: 14px;">
            If the button above doesn't work, copy and paste this link into your browser:
        </p>
        <p style="word-break: break-all; font-size: 12px; color: #0f3460;">
            <a href="{{resultsUrl}}" style="color: #0f3460;">{{resultsUrl}}</a>
        </p>

        {{#showPostCompletion}}
        <!-- Post-completion follow-up (survey or external link). -->
        <div style="border-top: 1px solid #e5e7eb; margin: 36px 0 24px;"></div>
        <div style="text-align: center; padding: 4px 0 8px;">
            <p style="color: #0f3460; font-size: 16px; font-weight: 700; margin: 0 0 6px;">
                {{{fields.postCompletionHeading}}}
            </p>
            <p style="color: #64748b; font-size: 14px; margin: 0 0 18px; line-height: 1.5;">
                {{{fields.postCompletionBody}}}
            </p>
            {{#postCompletionUrl}}
            <a href="{{postCompletionUrl}}"
               style="display: inline-block; background-color: #ffffff; color: #0f3460; text-decoration: none; padding: 11px 26px; border: 2px solid #0f3460; border-radius: 8px; font-size: 14px; font-weight: 600;">
                {{postCompletionLabel}}
            </a>
            {{/postCompletionUrl}}
        </div>
        {{/showPostCompletion}}
    </div>

    <!-- Footer -->
    <div style="padding: 16px 32px; text-align: center;">
        <p style="color: #94a3b8; font-size: 12px; margin: 0;">
            This is an automated message from BVisionRY.
        </p>
    </div>
</body>
</html>
